{
  "name": "sleekblue",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently -n vite,server -c blue,green \"vite\" \"node server.js\"",
    "client": "vite",
    "server": "node server.js",
    "build": "vite build",
    "deploy": "vite build && node server.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "playwright test",
    "test:report": "playwright show-report",
    "test:lint": "eslint .",
    "test:e2e": "playwright test tests/checkout-mobile.spec.ts",
    "test:perf": "lhci autorun",
    "test:load": "k6 run load-test.js",
    "test:qa": "bash run-qa-gate.sh",
    "start:prod": "pm2 start server.js --name sleekblue-api"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pm2": "^5.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.2.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-security": "^4.0.1",
    "globals": "^17.6.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "vite": "^8.0.12"
  }
}
