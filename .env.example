# ─────────────────────────────────────────────────────────────
# Sleekblue Media Houz — Environment Variables
# Copy this file to .env and fill in every value before deploying.
# NEVER commit your real .env file to version control.
# ─────────────────────────────────────────────────────────────

# Server port — Hostinger assigns this automatically; leave blank to default to 3000
PORT=

# JWT secret for admin authentication — use a long random string (min 32 chars)
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Admin credentials for the dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
